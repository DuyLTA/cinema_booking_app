class MovieListProvider extends ChangeNotifier {
  MovieListModel movieListModel = MovieListModel();
  TextEditingController searchController = TextEditingController();

  String selectedCinema = 'All Cinemas';
  int selectedDateIndex = 0;
  bool isLoading = false;
  String searchQuery = '';

  List<String> cinemas = [
    'All Cinemas',
    'Grand Rialto',
    'Majestic Marquee',
    'Vintage Cinema Lab',
    'Cine Booking Thao Dien',
  ];

  List<DateItemModel> dates = [
    DateItemModel(dayLabel: 'TODAY', dateNumber: '14'),
    DateItemModel(dayLabel: 'TUE', dateNumber: '15'),
    DateItemModel(dayLabel: 'WED', dateNumber: '16'),
    DateItemModel(dayLabel: 'THU', dateNumber: '17'),
    DateItemModel(dayLabel: 'FRI', dateNumber: '18'),
    DateItemModel(dayLabel: 'SAT', dateNumber: '19'),
    DateItemModel(dayLabel: 'SUN', dateNumber: '20'),
  ];

  List<MovieItemModel> _allMovies = [
    MovieItemModel(
      title: 'Midnight Protocol',
      durationGenre: '142 MIN • THRILLER',
      rating: 'R',
      posterImage: ImageConstant.imgAb6axubvoymt5hz,
    ),
    MovieItemModel(
      title: 'Velvet Curtains',
      durationGenre: '118 MIN • DRAMA',
      rating: 'PG-13',
      posterImage: ImageConstant.imgAb6axucy88sqqzi,
    ),
    MovieItemModel(
      title: 'The After Hour',
      durationGenre: '135 MIN • ACTION',
      rating: 'MA15+',
      posterImage: ImageConstant.imgAb6axubaruPhfk,
    ),
    MovieItemModel(
      title: 'Desert Echoes',
      durationGenre: '156 MIN • SCI-FI',
      rating: 'PG',
      posterImage: ImageConstant.imgAb6axucyza15xyp,
    ),
    MovieItemModel(
      title: 'Ghost Witness',
      durationGenre: '102 MIN • HORROR',
      rating: 'R',
      posterImage: ImageConstant.imgAb6axucagx7ffit,
    ),
    MovieItemModel(
      title: 'Enchanted Waltz',
      durationGenre: '95 MIN • MUSICAL',
      rating: 'G',
      posterImage: ImageConstant.imgAb6axuadhzqs19,
    ),
  ];

  List<MovieItemModel> get filteredMovies {
    if (searchQuery.isEmpty) return _allMovies;
    return _allMovies.where((movie) {
      return (movie.title ?? '').toLowerCase().contains(
            searchQuery.toLowerCase(),
          ) ||
          (movie.durationGenre ?? '').toLowerCase().contains(
            searchQuery.toLowerCase(),
          );
    }).toList();
  }

  @override
  void dispose() {
    searchController.dispose();
    super.dispose();
  }

  void initialize() {
    isLoading = false;
    notifyListeners();
  }

  void selectCinema(String cinema) {
    selectedCinema = cinema;
    notifyListeners();
  }

  void selectDate(int index) {
    selectedDateIndex = index;
    notifyListeners();
  }

  void onSearchChanged(String value) {
    searchQuery = value;
    notifyListeners();
  }
}
