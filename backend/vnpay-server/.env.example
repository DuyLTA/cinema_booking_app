PORT=8080
# Browser redirect after VNPay finishes. For Android emulator, use:
# VNPAY_RETURN_URL=http://10.0.2.2:8080/api/vnpay/return
# For physical devices, expose this backend with ngrok/cloudflared and use that public URL.
VNPAY_RETURN_URL=http://localhost:8080/api/vnpay/return
APP_DEEP_LINK=cinemabookingapp://payment-result

VNPAY_TMN_CODE=YOUR_SANDBOX_TMN_CODE
VNPAY_HASH_SECRET=YOUR_SANDBOX_HASH_SECRET
VNPAY_HOST=https://sandbox.vnpayment.vn
# Optional. Leave empty to let VNPay show supported payment methods.
# Examples: VNPAYQR, VNBANK, INTCARD
VNPAY_BANK_CODE=
# Demo only. Set true to force app to show payment error after VNPay returns.
VNPAY_FORCE_FAIL=false
